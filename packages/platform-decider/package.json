{
  "name": "@libar-dev/platform-decider",
  "version": "0.1.0",
  "description": "Pure Functional Event Sourcing Decider pattern - types and helpers for domain decision logic",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "peerDependencies": {
    "vitest": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:watch": "tsc --build --watch",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@amiceli/vitest-cucumber": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "decider",
    "event-sourcing",
    "functional",
    "ddd",
    "domain-driven-design",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/libar-dev/libar-dev-packages.git",
    "directory": "packages/platform/decider"
  },
  "homepage": "https://github.com/libar-dev/convex-event-sourcing#readme",
  "bugs": {
    "url": "https://github.com/libar-dev/convex-event-sourcing/issues"
  }
}
