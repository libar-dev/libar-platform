{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "ladle": "ladle serve",
    "ladle:build": "ladle build",
    "bddgen": "bddgen --config=tests/e2e/playwright.config.ts",
    "test:e2e": "pnpm bddgen && playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:headed": "pnpm bddgen && playwright test --config=tests/e2e/playwright.config.ts --headed",
    "test:e2e:debug": "pnpm bddgen && playwright test --config=tests/e2e/playwright.config.ts --debug",
    "test:e2e:ci": "pnpm bddgen && playwright test --config=tests/e2e/playwright.config.ts --project=chromium",
    "test:e2e:all": "PLAYWRIGHT_BDD_TAGS='' pnpm bddgen && playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:clean": "cd ../.. && just e2e-restart && cd apps/frontend && pnpm test:e2e:all"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@convex-dev/action-retrier": "catalog:",
    "@convex-dev/rate-limiter": "catalog:",
    "@convex-dev/react-query": "catalog:",
    "@convex-dev/workflow": "catalog:",
    "@convex-dev/workpool": "catalog:",
    "@hugeicons/core-free-icons": "catalog:",
    "@hugeicons/react": "catalog:",
    "@libar-dev/platform-bc": "workspace:*",
    "@libar-dev/platform-bus": "workspace:*",
    "@libar-dev/platform-core": "workspace:*",
    "@libar-dev/platform-store": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-router-ssr-query": "catalog:",
    "@tanstack/react-start": "catalog:",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-merge": "catalog:",
    "tw-animate-css": "^1.4.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@ladle/react": "^5.1.1",
    "@playwright/test": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "playwright-bdd": "catalog:",
    "shadcn": "catalog:",
    "tailwindcss": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:"
  }
}
